# ================================================
# Investment MCP Multi-Agent System — Environment
# ================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- App ---
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- Authentication ---
# Set to a strong random string to enable API key auth on /analyze routes.
# Leave empty to disable auth (local dev only).
# Header required when set:  X-API-Key: <value>
API_KEY=

# --- Rate Limiting ---
# Max analysis submissions per IP per time window.  Format: "N/unit" (unit: second/minute/hour)
RATE_LIMIT_ANALYZE=10/minute

# --- Database Migrations ---
# Set to "true" to use Alembic (alembic upgrade head) instead of SQLAlchemy create_all.
# Recommended for production; leave false for local dev.
USE_ALEMBIC=false

# --- Database ---
POSTGRES_DB=investment_db
POSTGRES_USER=invest_user
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://invest_user:your_secure_password_here@localhost:5432/investment_db
DATABASE_URL_ASYNC=postgresql+asyncpg://invest_user:your_secure_password_here@localhost:5432/investment_db

# --- LLM ---
# Replace with your real key from https://console.anthropic.com/
# Get a key: https://console.anthropic.com/ → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Demo Mode ---
# true  = synthetic reports, no Anthropic API calls (safe for demos without a key)
# false = live LLM analysis (requires valid ANTHROPIC_API_KEY)
DEMO_MODE=false

# --- External Data APIs (optional but recommended) ---
NEWS_API_KEY=your_newsapi_key_here
ALPHA_VANTAGE_KEY=your_alphavantage_key_here

# --- Analysis Defaults ---
DEFAULT_ANALYSIS_PERIOD=1y
MAX_CONCURRENT_RUNS=5
CREW_VERBOSE=false

# --- Monitoring ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=your_grafana_password_here

# --- UI (Docker only, set automatically in docker-compose) ---
BACKEND_URL=http://localhost:8000
