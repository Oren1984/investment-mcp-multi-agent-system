# =========================
# Application
# =========================
APP_NAME=shared-platform
APP_ENV=development
DEBUG=true

# =========================
# Logging
# =========================
LOG_LEVEL=INFO
LOG_FORMAT=standard
LOG_FILE=logs/app.log

# =========================
# Config
# =========================
CONFIG_SOURCE=env

# =========================
# Retry
# =========================
RETRY_ATTEMPTS=3
RETRY_DELAY=1

# =========================
# External Services (placeholders)
# =========================
API_TIMEOUT=10

# =========================
# Feature Flags
# =========================
ENABLE_VALIDATION=true
ENABLE_RETRY=true