# =========================
# RAG SYSTEM ENV
# =========================

APP_ENV=development
LOG_LEVEL=INFO

# Provider selection
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini

# Optional provider keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional local model endpoint
LOCAL_MODEL_BASE_URL=

# Retrieval settings
TOP_K=5
RERANK_ENABLED=true
RERANK_TOP_N=3

# Optional web connector
WEB_SEARCH_ENABLED=false
WEB_SEARCH_PROVIDER=
WEB_SEARCH_API_KEY=

# Observability
OTEL_ENABLED=false
PHOENIX_ENABLED=false
LANGSMITH_ENABLED=false

# Security
PII_MASKING_ENABLED=false
PROMPT_INJECTION_CHECK_ENABLED=true